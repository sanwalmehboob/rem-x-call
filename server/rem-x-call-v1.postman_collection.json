    {
      "name": "Dashboard",
      "description": "Home screen APIs for the mobile app — stats, recent calls, follow-ups.",
      "item": [
        {
          "name": "[Agent] Get Stats",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/v1/dashboard/stats?period=30d",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "dashboard", "stats"],
              "query": [
                { "key": "period", "value": "30d", "description": "30d | 60d | 90d | overall" }
              ]
            },
            "description": "Returns totalCalls, followUps, and percentage changes for the requested period."
          }
        },
        {
          "name": "[Agent] Recent Calls",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/v1/dashboard/recent-calls?limit=5",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "dashboard", "recent-calls"],
              "query": [
                { "key": "limit", "value": "5", "description": "Max results (default 5, max 50)" }
              ]
            },
            "description": "Recent call activity with contact info, duration, and status."
          }
        },
        {
          "name": "[Agent] Follow-Ups",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/v1/dashboard/follow-ups?limit=10&page=1&pageSize=10",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "dashboard", "follow-ups"],
              "query": [
                { "key": "limit", "value": "10", "description": "Max results (default 10, max 50)" },
                { "key": "page", "value": "1" },
                { "key": "pageSize", "value": "10" }
              ]
            },
            "description": "Contacts needing follow-up based on call outcomes."
          }
        },
        {
          "name": "[Agent] Product Overview",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/v1/dashboard/product-overview?period=30d",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "dashboard", "product-overview"],
              "query": [
                { "key": "period", "value": "30d", "description": "7d | 14d | 21d | 30d | 60d | 90d | overall" }
              ]
            },
            "description": "Dashboard overview of total products and products sold statistics."
          }
