  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "[Admin] Bootstrap First Admin",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"setupSecret\": \"your-setup-secret\",\n  \"username\": \"admin\",\n  \"email\": \"admin@example.com\",\n  \"password\": \"AdminPass123!\",\n  \"clientType\": \"web\"\n}"
            },
            "url": "{{baseUrl}}/v1/auth/bootstrap-first-admin"
          }
        },
        {
          "name": "[Agent] Register",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"newagent\",\n  \"email\": \"newagent@example.com\",\n  \"password\": \"Password123!\",\n  \"firstName\": \"New\",\n  \"lastName\": \"Agent\",\n  \"phone\": \"+15550001111\",\n  \"clientType\": \"mobile\",\n  \"deviceId\": \"android-device-001\",\n  \"platform\": \"android\",\n  \"appVersion\": \"1.0.0\"\n}"
            },
            "url": "{{baseUrl}}/v1/auth/register"
          }
        },
        {
          "name": "[Both] Login",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"AdminPass123!\",\n  \"clientType\": \"mobile\",\n  \"deviceId\": \"ios-device-001\",\n  \"deviceName\": \"Habib iPhone\",\n  \"platform\": \"ios\",\n  \"appVersion\": \"1.0.0\"\n}"
            },
            "url": "{{baseUrl}}/v1/auth/login"
          }
        },
        {
          "name": "[Both] Forgot Password",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\"\n}"
            },
            "url": "{{baseUrl}}/v1/auth/forgot-password",
            "description": "Send a 6-digit OTP to the user's email for password reset."
          }
        },
        {
          "name": "[Both] Verify Reset OTP",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"otp\": \"123456\"\n}"
            },
            "url": "{{baseUrl}}/v1/auth/verify-reset-otp",
            "description": "Verify the 6-digit OTP. Returns a resetToken on success."
          }
        },
        {
          "name": "[Both] Reset Password",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"resetToken\": \"paste-reset-token-here\",\n  \"newPassword\": \"NewSecurePass123!\"\n}"
            },
            "url": "{{baseUrl}}/v1/auth/reset-password",
            "description": "Complete password reset using the resetToken from verify-reset-otp."
          }
        },
        {
          "name": "[Both] Refresh Tokens",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\",\n  \"clientType\": \"mobile\",\n  \"appVersion\": \"1.0.1\"\n}"
            },
            "url": "{{baseUrl}}/v1/auth/refresh-tokens"
          }
        },
