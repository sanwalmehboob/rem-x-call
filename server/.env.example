PORT=5000
NODE_ENV=development

# Database
DB_HOST=127.0.0.1
DB_USER=root
DB_PASS=password
DB_NAME=rem_x_call
DB_PORT=3306

# After MySQL is running and DB exists, create tables:
#   cd server && npm run migrate
#
# First admin (no seeder): POST /v1/auth/bootstrap-first-admin with body
#   { "username":"admin","email":"you@corp.com","password":"YourPass12","setupSecret":"<SETUP_SECRET>" }
# Then create subscription plans (admin UI /billing or POST /v1/subscription-plans), then add a company
# (POST /v1/companies) to invite an agent by email with a temporary password.

SETUP_SECRET=change-me-long-random-string
APP_PUBLIC_URL=http://localhost:5173

# Browser origins allowed for API (comma-separated). Leave empty = reflect request Origin (good for staging).
# Example: CORS_ORIGINS=http://localhost:5173,http://YOUR_EC2_IP:8080
CORS_ORIGINS=

# Outbound email (RemXCall hosting). If SMTP_PASS is unset, outbound mail is skipped and a warning is logged.
# Incoming (reference only): IMAP mail.remxcall.co.za:993 / POP mail.remxcall.co.za:995
EMAIL_FROM=RemXCall <info@remxcall.co.za>
SMTP_HOST=smtp.remxcall.co.za
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=info@remxcall.co.za
SMTP_PASS=

# JWT
JWT_SECRET=your_super_secret_key_here
JWT_EXPIRES_IN=1d

# Forgot-password OTP (optional)
# PASSWORD_RESET_OTP_EXPIRES_MIN=15
# PASSWORD_RESET_TOKEN_EXPIRES_IN=15m

# AWS (Mock/Real)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_S3_BUCKET=

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# VICIDIAL
VICIDIAL_API_URL=
VICIDIAL_API_USER=
VICIDIAL_API_PASS=

# VoIP AMI settings
VOIP_AMI_IP=84.247.182.13
VOIP_AMI_TRUNK=229224203
